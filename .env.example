# Clima - obtenha sua chave gratuita em https://openweathermap.org/api
VITE_WEATHER_API_KEY=sua_chave_aqui
VITE_WEATHER_CITY=Vila Velha,BR

# Voz (ElevenLabs) - conta gratuita em https://elevenlabs.io (10.000 caracteres/mês)
# Sem essa chave, o sistema usa a voz nativa do navegador como fallback
VITE_ELEVENLABS_API_KEY=sua_chave_elevenlabs
# ID da voz desejada (padrão: Charlotte - multilingual)
# Veja outros IDs em: https://elevenlabs.io/docs/voices
VITE_ELEVENLABS_VOICE_ID=XB0fDUnXU5powFXDhCwa
